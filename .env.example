# Application database contract.
# The application only reads DATABASE_URL. Point it at either bundled Docker
# PostgreSQL or an externally managed PostgreSQL instance with pgvector enabled.

# Bundled Docker PostgreSQL defaults:
DATABASE_URL="postgresql://scout:scout_password@localhost:5432/scout"
APP_BASE_URL="http://localhost:3000"

# Optional SMTP settings. If SMTP_HOST is omitted, activation emails are kept
# in email_outbox for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Scout Admin <no-reply@localhost>"

# File storage.
STORAGE_PROVIDER=local
STORAGE_ROOT=./storage

# Embeddings.
EMBEDDING_PROVIDER=local_bge
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=768
EMBEDDING_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# LLM.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:0.6b
LLM_ENDPOINT=http://localhost:11434
LLM_API_KEY=
# Gemini example:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=

# External PostgreSQL example:
# DATABASE_URL="postgresql://app_user:strong_password@db.example.com:5432/scout?sslmode=require"

# Docker Compose bundled database settings.
# These are consumed by docker-compose.yml, not by application code.
POSTGRES_DB=scout
POSTGRES_USER=scout
POSTGRES_PASSWORD=scout_password
POSTGRES_PORT=5432

# First company/admin seed task.
SEED_COMPANY_NAME=Scout
SEED_COMPANY_SLUG=scout
SEED_ADMIN_NAME=First Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password

# Standalone Chatbot API service
CHATBOT_API_KEY=replace-with-a-long-random-api-key
CHATBOT_API_PORT=4200
CHATBOT_API_HOST=0.0.0.0
CHATBOT_API_ALLOWED_ORIGINS=*
CHATBOT_API_BODY_LIMIT_BYTES=262144
CHATBOT_API_COMPANY_CACHE_TTL_MS=300000
CHATBOT_API_TARGET_APP_CACHE_TTL_MS=300000
CHATBOT_API_AUTH_CACHE_TTL_MS=300000
CHATBOT_API_RATE_LIMIT_WINDOW_MS=60000
CHATBOT_API_RATE_LIMIT_MAX_REQUESTS=60
