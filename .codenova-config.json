{
  "version": "2.0.10",
  "workspace": "SHS_SYNXIS",
  "description": "CodeNova configuration for the shs_synxis.projectx workspace",
  "identity": {
    "name": "CodeNova",
    "mode": "copilot-chat-overlay",
    "commandPrefix": "codenova"
  },
  "rally": {
    "enabled": true,
    "apiUrl": "https://rally1.rallydev.com",
    "apiVersion": "v2.0",
    "authHeader": "ZSESSIONID",
    "apiKey": "enter your rally API key here",
    "workspace": "27154375360",
    "project": "HSPD",
    "defaultProject": "HSPD",
    "workItemPrefixes": {
      "FE": {
        "type": "Feature",
        "resource": "feature"
      },
      "TF": {
        "type": "Team Feature",
        "resource": "teamfeature"
      },
      "DE": {
        "type": "Defect",
        "resource": "defect"
      },
      "US": {
        "type": "User Story",
        "resource": "hierarchicalrequirement"
      },
      "TA": {
        "type": "Task",
        "resource": "task"
      },
      "DS": {
        "type": "Defect Suite",
        "resource": "defectsuite"
      }
    },
    "fetchFields": {
      "defect": "FormattedID,Name,Description,State,Priority,Severity,Owner,Project,Iteration,Release,CreationDate,LastUpdateDate,ScheduleState,Tags,Notes,Blocked,BlockedReason",
      "hierarchicalrequirement": "FormattedID,Name,Description,ScheduleState,Owner,Project,Iteration,PlanEstimate,AcceptanceCriteria,Tags,Notes,Blocked",
      "task": "FormattedID,Name,Description,State,Owner,WorkProduct,Estimate,Actuals,ToDo"
    }
  },
  "git": {
    "enabled": true,
    "repositories": [
      {
        "url": "https://github.com/sabre-internal/shs_synxis.projectx",
        "branch": "Master",
        "name": "shs_synxis.projectx"
      }
    ],
    "localPath": "."
  },
  "github": {
    "enabled": true,
    "repository": "sabre-internal/shs_synxis.projectx",
    "remoteUrl": "https://github.com/sabre-internal/shs_synxis.projectx.git",
    "localPath": ".",
    "defaultBranch": "master",
    "cli": "gh"
  },
  "executionPriorityOrder": [
    {
      "priority": 1,
      "label": "HIGHEST â€” Ask / Explain / Discover / Search / Scan",
      "condition": "Message carries ask, explain, discover, search, or scan semantic intent",
      "action": "codenova.task â†’ ask â†’ deep-discover:<subject>"
    },
    {
      "priority": 2,
      "label": "Multi-step workflow intent",
      "condition": "Message includes explicit multi-action sequencing (e.g. perform todo, step lists, numbered actions)",
      "action": "codenova:run workflow orchestrator"
    },
    {
      "priority": 3,
      "label": "Named CodeNova command",
      "condition": "Message matches a named CodeNova command (e.g. get, review pr, git fetch)",
      "action": "codenova.orchestrator or codenova.task (per command registry)"
    },
    {
      "priority": 4,
      "label": "LOWEST â€” Fallback",
      "condition": "No intent match; ambiguous or general-purpose Copilot request",
      "action": "Direct tool use (grep_search, semantic_search, etc.)"
    }
  ],
  "executors": {
    "orchestrator": {
      "invocation": "codenova.orchestrator.run(workflow, params)",
      "description": "Multi-step, stateful workflows requiring sequencing and context carry-forward",
      "workflows": {
        "run-workflow-orchestrator": [
          "parse ordered actions from user message",
          "map each action to codenova.task or codenova.orchestrator",
          "execute actions sequentially with context carry-forward",
          "collect artifacts and summarize final outcome"
        ],
        "connect-git": [
          "git fetch origin",
          "report new/updated refs"
        ],
        "review-pr": [
          "git fetch",
          "gh pr view",
          "gh pr diff",
          "load reviewnetskill net-review",
          "codenova.analyze per *.cs",
          "test-coverage-audit",
          "structured code review"
        ],
        "review-branch": [
          "git fetch",
          "gh pr list (branch filter)",
          "diff",
          "load reviewnetskill net-review",
          "test-coverage-audit",
          "structured review"
        ],
        "review-file": [
          "read attached/local file",
          "load reviewnetskill net-review (A-L)",
          "test-coverage-audit (H rules)",
          "structured review report"
        ],
        "review-impact": [
          "resolve method/symbol",
          "grep_search all callers (2 levels)",
          "assess risk per caller",
          "identify missing test coverage",
          "blast radius report"
        ],
        "git-fetch": [
          "git fetch origin",
          "summarize updated refs"
        ]
      }
    },
    "task": {
      "invocation": "codenova.task.run(task, params)",
      "description": "Single-step, stateless operations producing one discrete output",
      "tasks": {
        "hello": "Greet and confirm CodeNova is active",
        "help": "Show available commands",
        "get-rally-item": "Fetch a Rally work item by ID (DE/US/TA auto-detected)",
        "pr-diff": "Retrieve and display the full diff for a PR number",
        "git-status": "Show current branch and working tree status",
        "ask": "Answer HS domain questions with deep workspace discovery",
        "tax-skill": "Answer tax domain questions using indexed knowledge assets in .github/instructions/isf/taxskill/",
        "ohip-skill": "Answer OHIP domain Q&A and execute OHIP implementation modes using indexed knowledge assets in .github/instructions/isf/ohipskill/",
        "synxisnom-skill": "Answer SynXis nomenclature questions â€” app IDs, domain codes, solution files, and naming conventions using indexed knowledge assets in .github/instructions/isf/synxisnomskill/",
        "architect-skill": "Design architecture artifacts from SON requirements including SRD, impact analysis, AD2, ADRs, and story breakdown using indexed templates in .github/instructions/isf/architectskill/",
        "review-synxis-guidelines": "Review C# code against SynXis Developer Guidelines using indexed reviewnetskill assets (Categories A-L)",
        "review-synxis-checklist": "Run quick PR gate checklist from indexed PR_CHECKLIST.md",
        "review-file": "Review a locally changed or attached .cs file against net-review rules + run test audit (H rules)",
        "review-impact": "Resolve a method or symbol, find all callers in the workspace, assess blast radius, and report risk",
        "analyze-jenkins": "Analyze Jenkins build log from URL"
      }
    }
  },
