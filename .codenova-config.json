    "autoRefresh": {
      "layer1": {
        "mechanism": "Copilot instruction auto-trigger",
        "description": "Copilot silently runs refresh protocol whenever it edits or reviews a .cs file containing a tax identifier. Appends 'ðŸ“‹ Tax Skill Auto-Refresh' section to the response.",
        "configuredIn": ".github/instructions/codenova.instructions.md"
      },
      "layer2": {
        "mechanism": "Git post-commit hook",
        "description": "Fires after every commit. Detects committed .cs files that touch tax identifiers and prints a reminder in the terminal.",
        "scriptFile": "GitHelpers/post-commit",
        "installWith": "GitHelpers/copyHooksIntoGitDir.bat"
      },
      "layer3": {
        "mechanism": "VS Code FileSystemWatcher background task",
        "description": "PowerShell watcher starts automatically when the folder is opened. Monitors all *.cs files for tax identifier saves and prints a panel notification.",
        "taskFile": ".vscode/tasks.json",
        "scriptFile": "scripts/codenova-tax-watcher.ps1",
        "runOn": "folderOpen"
      }
    }
