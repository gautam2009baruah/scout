  "deepDiscover": {
    "protocol": "deep-discover",
    "steps": [
      {
        "step": 0,
        "name": "BRAIN_LOOKUP",
        "file": ".github/instructions/codenova.bridge",
        "description": "Consult brain db first â€” CONFIRMED skips Step 2; INFERRED or UNKNOWN continues"
      },
      {
        "step": 1,
        "name": "PARSE",
        "description": "Extract and normalize the entity, acronym, term, or concept from the user message"
      },
      {
        "step": 2,
        "name": "SEARCH",
        "description": "grep_search (exact + regex) and semantic_search â€” SKIP if Step 0 was CONFIRMED",
        "skipIf": "CONFIRMED"
      },
      {
        "step": 3,
        "name": "CROSS_REFERENCE",
        "description": "Correlate across source code, solution files, deploy configs, QA projects, infrastructure"
      },
      {
        "step": 4,
        "name": "SYNTHESIZE",
        "description": "Produce structured report: definition, architecture position, key files, deployment details, QA coverage, related components"
      },
      {
        "step": 5,
        "name": "CONFIDENCE",
        "description": "State what is confirmed vs. inferred; offer Rally fetch if evidence is insufficient"
      }
    ],
    "searchTargets": [
      "*.cs",
      "*.csproj",
      "*.sln",
      "*.xml",
      "*.json",
      "*.config",
      "*.md"
    ],
    "brainFile": ".github/instructions/codenova.bridge"
  },
