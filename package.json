{
  "name": "scout-chatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "chatbot-api:dev": "node --import ./scripts/db/load-env.mjs --import tsx services/chatbot-api/src/server.ts",
    "chatbot-api:start": "node --import ./scripts/db/load-env.mjs --import tsx services/chatbot-api/src/server.ts",
    "lint": "eslint .",
    "db:migrate": "node scripts/db/migrate.mjs",
    "db:seed:first-admin": "node scripts/db/seed-first-admin.mjs",
    "jobs:documents": "node scripts/jobs/worker.mjs",
    "jobs:worker": "npm run jobs:documents",
    "extension:build": "node scripts/build-extension.mjs",
    "triggers:schedule": "tsx scripts/jobs/orchestration-scheduler.ts",
    "triggers:email": "tsx scripts/email-trigger-poller.mjs"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "imap": "^0.8.17",
    "jodit": "^4.12.32",
    "lucide-react": "^0.468.0",
    "mailparser": "^3.9.14",
    "mammoth": "^1.12.0",
    "next": "^16.2.9",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "puppeteer": "^24.43.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.7.0",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.23.0",
    "typescript": "^5.5.3"
