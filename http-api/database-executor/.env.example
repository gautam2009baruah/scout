PORT=4300
HOST=0.0.0.0

# Choose one: postgresql, mysql, sqlserver
DB_TYPE=postgresql

# PostgreSQL
# Recommended: use one connection URL. URL-encode special characters in the password.
DATABASE_URL=postgresql://username:password@database-host:5432/database-name

# Alternative PostgreSQL fields. Leave DATABASE_URL empty when using these.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=postgres
DB_SCHEMA=public
DB_SSL=false

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=scout

# SQL Server
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_DATABASE=master
MSSQL_ENCRYPT=false
